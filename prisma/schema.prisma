// ============================================================
// DATABASE
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// IDENTITY & ACCESS
// ============================================================

enum Role {
  CUSTOMER
  ATTENDANT
  KITCHEN
  MANAGER
  ADMIN
}

model Users {
  id             String  @id @default(uuid())
  businessUnitId String? @map("business_unit_id")

  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  phone        String?  @unique
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  updatedById  String?  @map("updated_by")
  role         Role

  businessUnit BusinessUnits? @relation(fields: [businessUnitId], references: [id])
  updatedBy    Users?         @relation("UserUpdatedBy", fields: [updatedById], references: [id])

  customerOrders        Orders[]                @relation("CustomerOrders")
  attendantOrders       Orders[]                @relation("AttendantOrders")
  inventoryTransactions InventoryTransactions[]
  loyaltyAccounts       LoyaltyAccounts[]

  userUpdatedBy            Users[]           @relation("UserUpdatedBy")
  ordersUpdatedBy          Orders[]          @relation("OrdersUpdatedBy")
  loyaltyAccountsUpdatedBy LoyaltyAccounts[] @relation("LoyaltyAccountsUpdatedBy")

  @@index([role])
  @@index([businessUnitId])
  @@map("users")
}

// ============================================================
// BUSINESS UNITS & MENU
// ============================================================

model BusinessUnits {
  id        String   @id @default(uuid())
  name      String
  cnpj      String   @unique
  address   String
  city      String
  phone     String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users      Users[]
  orders     Orders[]
  menuItems  BusinessUnitMenuItems[]
  inventory  Inventory[]
  promotions Promotions[]

  @@map("business_units")
}

model Categories {
  id          String @id @default(uuid())
  name        String @unique
  description String

  products Products[]

  @@map("categories")
}

model Products {
  id         String @id @default(uuid())
  categoryId String @map("category_id")

  name        String   @unique
  description String?
  basePrice   Decimal  @map("base_price") @db.Decimal(10, 2)
  imageUrl    String   @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category   Categories              @relation(fields: [categoryId], references: [id])
  menuItems  BusinessUnitMenuItems[]
  inventory  Inventory[]
  orderItems OrderItems[]

  @@index([categoryId])
  @@index([isActive])
  @@map("products")
}

model BusinessUnitMenuItems {
  id             String @id @default(uuid())
  businessUnitId String @map("business_unit_id")
  productId      String @map("product_id")

  customPrice Decimal  @map("custom_price") @db.Decimal(10, 2)
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  businessUnit BusinessUnits @relation(fields: [businessUnitId], references: [id])
  product      Products      @relation(fields: [productId], references: [id])

  @@unique([businessUnitId, productId])
  @@map("business_unit_menu_items")
}

// ============================================================
// INVENTORY
// ============================================================

enum InventoryTransactionType {
  IN
  OUT
  ADJUSTMENT
  RESERVE
}

model Inventory {
  id             String @id @default(uuid())
  businessUnitId String @map("business_unit_id")
  productId      String @map("product_id")

  quantity    Int
  minQuantity Int      @map("min_quantity")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  businessUnit BusinessUnits @relation(fields: [businessUnitId], references: [id])
  product      Products      @relation(fields: [productId], references: [id])

  inventoryTransactions InventoryTransactions[]

  @@unique([businessUnitId, productId])
  @@map("inventory")
}

model InventoryTransactions {
  id          String  @id @default(uuid())
  inventoryId String  @map("inventory_id")
  orderId     String? @map("order_id")
  createdBy   String  @map("created_by")

  type      InventoryTransactionType
  quantity  Int
  reason    String
  createdAt DateTime                 @default(now()) @map("created_at")

  inventory     Inventory @relation(fields: [inventoryId], references: [id])
  order         Orders?   @relation(fields: [orderId], references: [id])
  createdByUser Users     @relation(fields: [createdBy], references: [id])

  @@index([inventoryId])
  @@index([orderId])
  @@index([createdBy])
  @@index([createdAt])
  @@map("inventory_transactions")
}

// ============================================================
// ORDERS
// ============================================================

enum OrderChannel {
  APP
  WEB
  TOTEM
  COUNTER
  PICKUP
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model Orders {
  id             String  @id @default(uuid())
  businessUnitId String  @map("business_unit_id")
  customerId     String  @map("customer_id")
  attendantId    String? @map("attendant_id")

  pointsRedeemed Int          @default(0) @map("points_redeemed")
  pointsEarned   Int          @default(0) @map("points_earned")
  totalAmount    Decimal      @map("total_amount") @db.Decimal(10, 2)
  notes          String?
  orderChannel   OrderChannel @map("order_channel")
  orderStatus    OrderStatus  @default(PENDING) @map("order_status")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  updatedById    String?      @map("updated_by")

  businessUnit BusinessUnits @relation(fields: [businessUnitId], references: [id])
  customer     Users         @relation("CustomerOrders", fields: [customerId], references: [id])
  attendant    Users?        @relation("AttendantOrders", fields: [attendantId], references: [id])
  updatedBy    Users?        @relation("OrdersUpdatedBy", fields: [updatedById], references: [id])

  inventoryTransactions InventoryTransactions[]
  orderItems            OrderItems[]
  payments              Payments[]
  orderPromotions       OrderPromotions[]
  loyaltyTransactions   LoyaltyTransactions[]

  @@index([customerId])
  @@index([businessUnitId])
  @@index([orderStatus])
  @@index([orderChannel])
  @@index([createdAt])
  @@map("orders")
}

model OrderItems {
  id        String @id @default(uuid())
  orderId   String @map("order_id")
  productId String @map("product_id")

  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
  notes     String?

  order   Orders   @relation(fields: [orderId], references: [id])
  product Products @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ============================================================
// PAYMENTS
// ============================================================

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  CASH
  VOUCHER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  APPROVED
  REFUSED
  CANCELLED
}

model Payments {
  id      String @id @default(uuid())
  orderId String @unique @map("order_id")

  amount           Decimal       @db.Decimal(10, 2)
  method           PaymentMethod
  status           PaymentStatus @default(PENDING)
  extTransactionId String?       @map("ext_transaction_id")
  gatewayRequest   Json?         @map("gateway_request")
  gatewayResponse  Json?         @map("gateway_response")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  order Orders @relation(fields: [orderId], references: [id])

  @@index([status])
  @@map("payments")
}

// ============================================================
// PROMOTIONS
// ============================================================

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_ITEM
}

model Promotions {
  id             String @id @default(uuid())
  businessUnitId String @map("business_unit_id")

  name          String
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(10, 2)
  minOrderValue Decimal      @map("min_order_value") @db.Decimal(10, 2)
  startDate     DateTime     @map("start_date")
  endDate       DateTime     @map("end_date")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  businessUnit BusinessUnits @relation(fields: [businessUnitId], references: [id])

  orderPromotions OrderPromotions[]

  @@index([businessUnitId])
  @@index([isActive, startDate, endDate])
  @@map("promotions")
}

model OrderPromotions {
  id          String @id @default(uuid())
  orderId     String @map("order_id")
  promotionId String @map("promotion_id")

  discountApplied Decimal @map("discount_applied") @db.Decimal(10, 2)

  order     Orders     @relation(fields: [orderId], references: [id])
  promotion Promotions @relation(fields: [promotionId], references: [id])

  @@map("order_promotions")
}

// ============================================================
// LOYALTY
// ============================================================

enum LoyaltyTransactionType {
  EARN
  REDEEM
  EXPIRE
  ADJUSTMENT
}

model LoyaltyAccounts {
  id         String @id @default(uuid())
  customerId String @unique @map("customer_id")

  totalPoints  Int       @default(0) @map("total_points")
  consentGiven Boolean   @default(false) @map("consent_given")
  consentDate  DateTime? @map("consent_date")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  updatedById  String?   @map("updated_by")

  customer  Users  @relation(fields: [customerId], references: [id])
  updatedBy Users? @relation("LoyaltyAccountsUpdatedBy", fields: [updatedById], references: [id])

  loyaltyTransactions LoyaltyTransactions[]

  @@map("loyalty_accounts")
}

model LoyaltyTransactions {
  id               String  @id @default(uuid())
  loyaltyAccountId String  @map("loyalty_account_id")
  orderId          String? @map("order_id")

  type        LoyaltyTransactionType
  points      Int
  description String
  createdAt   DateTime               @default(now()) @map("created_at")

  loyaltyAccount LoyaltyAccounts @relation(fields: [loyaltyAccountId], references: [id])
  order          Orders?         @relation(fields: [orderId], references: [id])

  @@index([loyaltyAccountId])
  @@index([orderId])
  @@map("loyalty_transactions")
}
